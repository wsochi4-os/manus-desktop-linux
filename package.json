{
  "name": "manus-desktop-linux",
  "version": "1.0.0",
  "description": "Manus Desktop App for Linux",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --linux deb appimage"
  },
  "author": "Manus <support@manus.ai>",
  "license": "MIT",
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "electron-tray": "^0.1.1",
    "electron-window-state": "^5.0.3"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.manus.desktop.linux",
    "productName": "Manus Desktop",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        "deb",
        "AppImage"
      ],
      "category": "Utility",
      "desktop": {
        "StartupWMClass": "ManusDesktop"
      }
    },
    "files": [
      "**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}"
    ],
    "extraResources": [
      "icon.png"
    ]
  }
}
